{
  "name": "vscode-messenger-devtools",
	"displayName": "VS Code Messenger Devtools",
	"description": "Helpful message exchange visualization",
	"version": "0.2.0",
	"engines": {
		"vscode": "^1.53.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
        "onCommand:vscode-messenger-devtools.helloWorld"
	],
	"main": "./lib/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "vscode-messenger-devtools.helloWorld",
				"title": "Hello World"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./lib/test/runTest.js"
	},
	"devDependencies": {
		"@types/vscode": "^1.53.0",
		"@typescript-eslint/eslint-plugin": "^5.15.0",
		"@typescript-eslint/parser": "^5.15.0",
		"eslint": "^8.11.0",
		"typescript": "^4.6.2"
	}
}
